{
  "name": "meteoblick-backend",
  "version": "1.0.0",
  "description": "MeteoSwiss weather data API for Meteoblick app",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS='--dns-result-order=ipv4first' tsx watch src/index.ts",
    "build": "prisma generate",
    "start": "NODE_OPTIONS='--dns-result-order=ipv4first' tsx src/index.ts",
    "sync": "NODE_OPTIONS='--dns-result-order=ipv4first' tsx src/cron/sync-weather.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "heroku-postbuild": "prisma generate"
  },
  "keywords": [
    "weather",
    "meteoswiss",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@hono/node-server": "^2.0.6",
    "@hono/zod-openapi": "^1.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "7.8.0",
    "@scalar/hono-api-reference": "^0.5.170",
    "dotenv": "^17.4.2",
    "hono": "^4.6.14",
    "node-cron": "^3.0.3",
    "papaparse": "^5.4.1",
    "pg": "^8.22.0",
    "prisma": "7.8.0",
    "tsx": "4.19.2",
    "undici": "^6.27.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "@types/papaparse": "^5.3.15",
    "@types/pg": "^8.20.0",
    "@vitest/ui": "^4.1.9",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": "24.18",
    "pnpm": "10.28.2"
  },
  "packageManager": "pnpm@10.28.2+sha512.41872f037ad22f7348e3b1debbaf7e867cfd448f2726d9cf74c08f19507c31d2c8e7a11525b983febc2df640b5438dee6023ebb1f84ed43cc2d654d2bc326264"
}