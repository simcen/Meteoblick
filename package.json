{
  "name": "meteoblick",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@bottom-tabs/react-navigation": "^1.3.1",
    "@expo/ui": "^57.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native/virtualized-lists": "^0.86.0",
    "@react-navigation/native": "^7.3.5",
    "expo": "~57.0.2",
    "expo-background-fetch": "^57.0.2",
    "expo-blur": "^57.0.0",
    "expo-modules-core": "^57.0.2",
    "expo-status-bar": "~57.0.0",
    "expo-task-manager": "^57.0.2",
    "expo-widgets": "^57.0.2",
    "papaparse": "^5.5.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.25.2",
    "react-native-shared-group-preferences": "^1.1.24"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "^29.5.14",
    "@types/papaparse": "^5.5.2",
    "@types/react": "~19.2.2",
    "jest": "^29.7.0",
    "jest-expo": "^57.0.1",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "dev": "expo start --clear",
    "ios": "expo run:ios --device 'iPhone 17 Pro'",
    "ios:clean": "rm -rf ios/build && expo run:ios --device 'iPhone 17 Pro'",
    "ios:widget": "pnpm ios && ./scripts/reset-widget.sh",
    "ios:bundle": "npx expo export:embed --entry-file index.ts --platform ios --dev false --bundle-output ios/main.jsbundle --assets-dest ios",
    "ios:archive": "pnpm ios:bundle && cd ios && xcodebuild -workspace Meteoblick.xcworkspace -scheme Meteoblick -configuration Release -archivePath build/Meteoblick.xcarchive archive",
    "ios:install": "cd ios && xcrun devicectl device install app --device $(xcrun devicectl list devices 2>/dev/null | grep 'iPhone' | grep 'connected' | awk '{print $3}' | head -1) build/Meteoblick.xcarchive/Products/Applications/Meteoblick.app",
    "ios:deploy": "./scripts/deploy-ios.sh",
    "ios:deploy:force": "pnpm ios:archive && pnpm ios:install",
    "widget:reset": "./scripts/reset-widget.sh",
    "android": "expo run:android",
    "web": "expo start --web",
    "clean": "rm -rf node_modules/.cache && rm -rf .expo && watchman watch-del-all 2>/dev/null || true",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "private": true,
  "packageManager": "pnpm@10.28.2+sha512.41872f037ad22f7348e3b1debbaf7e867cfd448f2726d9cf74c08f19507c31d2c8e7a11525b983febc2df640b5438dee6023ebb1f84ed43cc2d654d2bc326264"
}
