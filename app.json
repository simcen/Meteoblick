{
  "expo": {
    "name": "Meteoblick",
    "slug": "Meteoblick",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "meteoblick",
    "extra": {
      "apiBaseUrl": "http://172.16.100.10:3000"
    },
    "ios": {
      "bundleIdentifier": "ch.meteoblick",
      "buildNumber": "6",
      "deploymentTarget": "18.0",
      "supportsTablet": true,
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.ch.meteoblick"
        ]
      },
      "infoPlist": {
        "UIBackgroundModes": [
          "fetch"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "ch.meteoblick"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-widgets",
        {
          "widgets": [
            {
              "name": "MeteoblickWidget",
              "displayName": "Meteoblick",
              "description": "Wetterprognose für gewählten Standort",
              "supportedFamilies": [
                "systemSmall",
                "systemMedium",
                "systemLarge"
              ],
              "contentMarginsDisabled": true
            }
          ]
        }
      ],
      "expo-status-bar"
    ]
  }
}
